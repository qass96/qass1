{
  "manifest_version": 3,
  "name": "QA 증적 캡처",
  "version": "1.9",
  "description": "탭 전환 및 스크롤 시 자동 풀페이지 캡처 증적 도구",
  "permissions": ["tabs", "activeTab", "storage", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "QA 증적 캡처"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
